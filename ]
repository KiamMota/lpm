#include "base.hpp"
#include "cli_base.hpp"
#include "commands.hpp"
#include <iostream>
#include <vector>

int main(int argn, char **argv) {
  if (argn == 1) {
    cli::help();
    return 0;
  }

  std::string cmd = argv[1];

  // comandos que não dependem de nada
  if (cmd == "--version" || cmd == "-v") {
    cli::version();
    return 0;
  }
  if (cmd == "--help" || cmd == "-h") {
    cli::help();
    return 0;
  }
  if (cmd == "--self-update") {
    commands::self_update();
    return 0;
  }

  if (!base::is_nvim_installed()) {
    std::cout << "woops! neovim is not installed in your system!" << std::endl;
    return 1;
  }

  if (!base::is_lazy_installed()) {
    std::cout << "woops! lazy is not installed!" << std::endl;
    if (!cli::msg_question("do you wanna install lazy?")) {
      std::cout << "aborted." << std::endl;
      return 1;
    }
    commands::install_lazy();
  }

  base::start_nvPath();

  for (int i = 2; i < argn; i++)
    cli::main_args.push_back(argv[i]);

  if (cmd == "list") {
    commands::list();
    return 0;
  }
  if (cmd == "install") {
    commands::install(cli::main_args);
    return 0;
  }
  if (cmd == "remove") {
    commands::remove(cli::main_args);
    return 0;
  }
  if (cmd == "enable") {
    commands::activate(cli::main_args);
    return 0;
  }
  if (cmd == "deactivate") {
    commands::deactivate(cli::main_args);
    return 0;
  }
  if (cmd == "cat") {
    commands::cat(cli::main_args);
    return 0;
  }
  if (cmd == "edit") {
    commands::edit(cli::main_args);
    return 0;
  }

  std::cout << "unknown command: '" << cmd << "'\n" << std::endl;
  cli::help();
  return 1;
}
